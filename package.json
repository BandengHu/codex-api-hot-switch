{
  "name": "codex-api-hot-switch",
  "version": "0.1.0",
  "description": "Codex SwitchGate local API relay and desktop console.",
  "author": "Local",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --port 8787",
    "build": "next build",
    "preview": "npm exec --yes pnpm@10.21.0 -- build && node scripts/start-standalone.cjs",
    "desktop": "electron .",
    "desktop:build": "npm exec --yes pnpm@10.21.0 -- build && node scripts/prepare-electron-build.cjs && node scripts/generate-windows-icon.cjs && npm exec --yes pnpm@10.21.0 -- exec electron-builder --win nsis",
    "desktop:dir": "npm exec --yes pnpm@10.21.0 -- build && node scripts/prepare-electron-build.cjs && node scripts/generate-windows-icon.cjs && npm exec --yes pnpm@10.21.0 -- exec electron-builder --dir",
    "start": "node scripts/start-standalone.cjs",
    "test": "tsx --test lib/provider-clone.test.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@openai/agents": "^0.12.0",
    "@vercel/analytics": "1.6.1",
    "@wecom/aibot-node-sdk": "1.0.6",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fzstd": "0.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "^19",
    "react-dom": "^19",
    "server-only": "0.0.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "ws": "8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  },
  "build": {
    "appId": "local.codex.api-hot-switch",
    "productName": "Codex SwitchGate",
    "directories": {
      "app": ".electron-shell",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!node_modules/**/*",
      "!**/node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": ".electron-server",
        "to": "app",
        "filter": [
          "**",
          "**/*",
          "vendor/**",
          "!.data/**"
        ]
      }
    ],
    "electronDist": "node_modules/electron/dist",
    "electronVersion": "42.4.0",
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/app-icon-switch.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
